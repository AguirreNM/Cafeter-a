*.nuget.props
*.nuget.targets
nuget.config

# ── ASP.NET Core ───────────────────────────────────────────
# IMPORTANTE: appsettings.json contiene la cadena de conexión.
# Si usas Azure u otra BD con credenciales, muévelas a appsettings.Development.json
# y usa variables de entorno o Azure Key Vault en producción.
appsettings.Development.json
# El archivo .example SÍ se sube como guía para otros devs
!appsettings.Development.json.example

