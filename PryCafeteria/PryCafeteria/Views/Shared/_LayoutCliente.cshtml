<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Cafetería Starbucks</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .navbar-cliente {
            background: var(--green-800, #1B4332);
            padding: 0 24px;
            height: 60px;
            display: flex;
            align-items: center;
            gap: 24px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 8px rgba(0,0,0,.25);
        }
        .navbar-brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: #fff;
            font-weight: 700;
            font-size: 1.1rem;
        }
        .navbar-brand-logo img { width: 36px; height: 36px; border-radius: 50%; }
        .navbar-links { display: flex; gap: 4px; margin-left: auto; align-items: center; }
        .navbar-links a {
            color: rgba(255,255,255,.85);
            text-decoration: none;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: .9rem;
            transition: background .15s;
        }
        .navbar-links a:hover, .navbar-links a.active { background: rgba(255,255,255,.15); color: #fff; }
        .carrito-badge-wrap { position: relative; display: inline-flex; }
        .carrito-count {
            position: absolute;
            top: -6px; right: -6px;
            background: #e74c3c;
            color: #fff;
            font-size: .6rem;
            font-weight: 700;
            min-width: 16px; height: 16px;
            border-radius: 9999px;
            display: flex; align-items: center; justify-content: center;
            padding: 0 3px;
        }
        .page-cliente { max-width: 1200px; margin: 0 auto; padding: 24px 16px; }
        .cliente-footer {
            text-align: center;
            padding: 20px;
            font-size: .8rem;
            color: #666;
            border-top: 1px solid #e5e7eb;
            margin-top: 40px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body style="background:#f9fafb; min-height:100vh; display:flex; flex-direction:column;">

<nav class="navbar-cliente">
    <a class="navbar-brand-logo" asp-controller="Catalogo" asp-action="Index">
        <img src="~/images/starbucks_logo.png" alt="Starbucks" />
        Cafetería
    </a>
    <div class="navbar-links">
        <a asp-controller="Catalogo" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Catalogo" ? "active" : "")">
            <i class="bi bi-cup-hot me-1"></i>Menú
        </a>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Carrito" asp-action="Index"
               class="carrito-badge-wrap @(ViewContext.RouteData.Values["controller"]?.ToString() == "Carrito" ? "active" : "")"
               title="Ver carrito">
                <i class="bi bi-cart3 me-1"></i>Carrito
                @{ var _cnt = ViewBag.CarritoItems as int? ?? 0; }
                @if (_cnt > 0)
                {
                    <span class="carrito-count" id="carrito-badge">@_cnt</span>
                }
                else
                {
                    <span class="carrito-count" id="carrito-badge" style="display:none">0</span>
                }
            </a>
            <a asp-controller="Pedidos" asp-action="MisPedidos"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Pedidos" ? "active" : "")">
                <i class="bi bi-bag-check me-1"></i>Mis pedidos
            </a>
            <a asp-controller="Direcciones" asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Direcciones" ? "active" : "")">
                <i class="bi bi-geo-alt me-1"></i>Mis direcciones
            </a>
            <span style="color:rgba(255,255,255,.3);">|</span>
            <!-- Menú desplegable de usuario -->
            <div class="dropdown" style="position:relative;">
                <button class="dropdown-toggle" data-bs-toggle="dropdown"
                        style="background:rgba(255,255,255,.12);border:none;color:#fff;padding:7px 14px;border-radius:8px;font-size:.88rem;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:7px;">
                    <span style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.25);display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;">
                        @((User.FindFirst("Nombre")?.Value ?? User.Identity?.Name ?? "U").Substring(0,1).ToUpper())
                    </span>
                    @(User.FindFirst("Nombre")?.Value ?? User.Identity?.Name)
                    <i class="bi bi-chevron-down" style="font-size:.7rem;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end" style="min-width:180px;border-radius:10px;border:1px solid #e5e7eb;box-shadow:0 8px 24px rgba(0,0,0,.12);padding:6px;">
                    <li>
                        <a asp-controller="Perfil" asp-action="Index" class="dropdown-item" style="border-radius:7px;font-size:.87rem;padding:8px 12px;">
                            <i class="bi bi-person-circle me-2 text-success"></i>Mi perfil
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Pedidos" asp-action="MisPedidos" class="dropdown-item" style="border-radius:7px;font-size:.87rem;padding:8px 12px;">
                            <i class="bi bi-bag-check me-2 text-success"></i>Mis pedidos
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Direcciones" asp-action="Index" class="dropdown-item" style="border-radius:7px;font-size:.87rem;padding:8px 12px;">
                            <i class="bi bi-geo-alt me-2 text-success"></i>Mis direcciones
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" style="margin:4px 0;"></li>
                    <li>
                        <form asp-controller="Cuentas" asp-action="Logout" method="post" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item" style="border-radius:7px;font-size:.87rem;padding:8px 12px;color:#ef4444;width:100%;text-align:left;">
                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <a asp-controller="Cuentas" asp-action="Login">
                <i class="bi bi-person me-1"></i>Ingresar
            </a>
        }
    </div>
</nav>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mx-4 mt-3 mb-0" role="alert" style="max-width:1200px;margin-left:auto;margin-right:auto;">
        <i class="bi bi-check-circle me-2"></i>@TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mx-4 mt-3 mb-0" role="alert" style="max-width:1200px;margin-left:auto;margin-right:auto;">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show mx-4 mt-3 mb-0" role="alert" style="max-width:1200px;margin-left:auto;margin-right:auto;">
        <i class="bi bi-info-circle me-2"></i>@TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<main style="flex:1;">
    <div class="page-cliente">
        @RenderBody()
    </div>
</main>

<footer class="cliente-footer">
    &copy; 2026 Cafetería Starbucks — Sistema de pedidos online
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
// Actualiza el badge del carrito después de agregar productos (AJAX)
function actualizarBadgeCarrito(total) {
    var badge = document.getElementById('carrito-badge');
    if (!badge) return;
    if (total > 0) {
        badge.textContent = total;
        badge.style.display = 'flex';
    } else {
        badge.style.display = 'none';
    }
}
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
