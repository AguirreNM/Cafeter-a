@{
    ViewData["Title"] = "Error del servidor";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>500 — Cafetería Starbucks</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #374151 0%, #111827 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .error-box {
            background: #fff; border-radius: 24px; padding: 52px 48px;
            text-align: center; max-width: 480px; width: 90%;
            box-shadow: 0 24px 80px rgba(0,0,0,.3);
        }
        .error-num { font-size: 6rem; font-weight: 900; color: #ef4444; line-height: 1; letter-spacing: -.05em; }
        .error-icon {
            width: 72px; height: 72px; border-radius: 50%;
            background: #fef2f2; border: 3px solid #fecaca;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px; font-size: 1.8rem;
        }
        h1 { font-size: 1.4rem; font-weight: 800; color: #111827; margin: 12px 0 8px; }
        p { color: #6b7280; font-size: .95rem; margin-bottom: 28px; }
        .btn-home {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 28px; background: #1B4332; color: #fff;
            border-radius: 10px; text-decoration: none; font-weight: 700;
            transition: transform .15s;
        }
        .btn-home:hover { transform: translateY(-2px); color: #fff; }
        .btn-back {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 10px 20px; border: 1px solid #d1d5db; color: #374151;
            border-radius: 10px; text-decoration: none; font-weight: 600; font-size: .9rem;
            margin-left: 8px;
        }
        .btn-back:hover { background: #f9fafb; color: #111827; }
    </style>
</head>
<body>
    <div class="error-box">
        <div class="error-num">500</div>
        <div class="error-icon"><i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;"></i></div>
        <h1>Error interno del servidor</h1>
        <p>Algo salió mal en nuestro sistema. Nuestro equipo ya fue notificado y está trabajando en solucionarlo.</p>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn-home">
                <i class="bi bi-house"></i> Ir al Inicio
            </a>
            <a href="javascript:location.reload()" class="btn-back">
                <i class="bi bi-arrow-clockwise"></i> Reintentar
            </a>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
