@model IEnumerable<PryCafeteria.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
    var total = Model.Count();
}

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Categorías</h1>
        <p class="page-subtitle">Organiza el menú por grupos</p>
    </div>
    <a asp-action="Create" class="btn-cta">
        <i class="bi bi-plus-lg"></i> Nueva categoría
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill"></i> @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Búscador -->
<div class="inv-search-bar">
    <i class="bi bi-search inv-search-icon"></i>
    <input type="text" id="catSearch" class="inv-search-input"
           placeholder="Buscar categoría..." autocomplete="off" />
    <span class="inv-search-count" id="catCount">@total categoría@(total != 1 ? "s" : "")</span>
</div>

<div class="data-card">
    <div class="data-card-header">
        <span class="data-card-title">Todas las categorías</span>
        <span class="data-card-count" id="catTableCount">@total</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-folder2"></i></div>
            <div class="empty-state-title">Sin categorías</div>
            <div class="empty-state-sub">Crea la primera categoría del menú</div>
        </div>
    }
    else
    {
        <table class="modern-table" id="catTable">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Productos</th>
                    <th>Fecha creación</th>
                    <th style="text-align:right;width:100px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="catBody">
                @foreach (var item in Model)
                {
                    <tr class="cat-row" data-nombre="@item.NombreCategoria.ToLower()">
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="width:32px;height:32px;border-radius:8px;background:var(--gold-100);display:flex;align-items:center;justify-content:center;color:var(--gold-800);font-size:0.9rem;flex-shrink:0;">
                                    <i class="bi bi-folder2" aria-hidden="true"></i>
                                </div>
                                <span class="cell-primary">@item.NombreCategoria</span>
                            </div>
                        </td>
                        <td>
                            <span class="badge-modern @(item.Productos.Count > 0 ? "badge-disponible" : "badge-nodisponible")">
                                <span class="dot" aria-hidden="true"></span>
                                @item.Productos.Count producto@(item.Productos.Count != 1 ? "s" : "")
                            </span>
                        </td>
                        <td class="cell-secondary cell-mono">
                            @item.FechaCreacion.ToString("dd/MM/yyyy")
                        </td>
                        <td style="text-align:right;">
                            <div class="inv-menu-wrap">
                                <button class="inv-menu-btn" type="button" onclick="toggleMenu(this)" aria-label="Acciones">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <div class="inv-dropdown">
                                    <a asp-action="Edit" asp-route-id="@item.CategoriaId" class="inv-dropdown-item">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <div class="inv-dropdown-divider"></div>
                                    <a asp-action="Delete" asp-route-id="@item.CategoriaId" class="inv-dropdown-item inv-dropdown-danger">
                                        <i class="bi bi-trash3"></i> Eliminar
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" id="catNoResults" style="display:none;">
            <div class="empty-state-icon"><i class="bi bi-search"></i></div>
            <div class="empty-state-title">Sin resultados</div>
            <div class="empty-state-sub">No se encontró ninguna categoría con ese nombre</div>
        </div>
    }
</div>

@section Scripts {
<script>
const catRows = () => [...document.querySelectorAll('#catBody .cat-row')];
const catNoRes  = document.getElementById('catNoResults');
const catCount  = document.getElementById('catCount');
const catTC     = document.getElementById('catTableCount');

document.getElementById('catSearch')?.addEventListener('input', function () {
    const q = this.value.toLowerCase();
    let vis = 0;
    catRows().forEach(r => {
        const show = !q || r.dataset.nombre.includes(q);
        r.style.display = show ? '' : 'none';
        if (show) vis++;
    });
    if (catNoRes)  catNoRes.style.display  = vis === 0 ? '' : 'none';
    if (catCount)  catCount.textContent    = vis + ' categoría' + (vis !== 1 ? 's' : '');
    if (catTC)     catTC.textContent       = vis;
});

function toggleMenu(btn) {
    document.querySelectorAll('.inv-dropdown.open').forEach(d => {
        if (d !== btn.nextElementSibling) d.classList.remove('open');
    });
    btn.nextElementSibling.classList.toggle('open');
}
document.addEventListener('click', e => {
    if (!e.target.closest('.inv-menu-wrap'))
        document.querySelectorAll('.inv-dropdown.open').forEach(d => d.classList.remove('open'));
});
</script>
}
