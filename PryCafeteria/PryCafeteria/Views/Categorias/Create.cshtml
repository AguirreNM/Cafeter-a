@model PryCafeteria.Models.Categoria

@{
    ViewData["Title"] = "Nueva categoría";
}

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Nueva categoría</h1>
        <p class="page-subtitle">Agrupa los productos del menú</p>
    </div>
    <a asp-action="Index" class="btn-cancel" style="width:auto;padding:0.52rem 1rem;">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Volver
    </a>
</div>

<div style="max-width:480px;margin:0 auto;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon">
                <i class="bi bi-folder-plus" aria-hidden="true"></i>
            </div>
            <div>
                <div class="form-card-title">Crear categoría</div>
                <div class="form-card-subtitle">Las categorías organizan el catálogo de productos</div>
            </div>
        </div>
        <div class="form-card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="field-group">
                    <label asp-for="NombreCategoria" class="form-label">
                        <i class="bi bi-folder2" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>
                        Nombre de la categoría
                    </label>
                    <input asp-for="NombreCategoria" class="form-control" placeholder="Ej. Bebidas Calientes, Frappés…" />
                    <span asp-validation-for="NombreCategoria" class="field-error"></span>
                    <p class="field-hint">Solo letras, espacios y guiones. Entre 3 y 50 caracteres.</p>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-floppy" aria-hidden="true"></i> Guardar categoría
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
