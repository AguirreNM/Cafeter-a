@model IEnumerable<PryCafeteria.Models.MetodosPago>
@{ ViewData["Title"] = "Métodos de Pago"; var total = Model.Count(); }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Métodos de Pago</h1>
        <p class="page-subtitle">Gestiona las formas de pago disponibles en el sistema</p>
    </div>
    <a asp-action="Create" class="btn-cta btn-cta-pulse">
        <i class="bi bi-plus-lg" aria-hidden="true"></i> Nuevo Método
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill"></i> @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Búsqueda -->
<div class="inv-search-bar">
    <i class="bi bi-search inv-search-icon"></i>
    <input type="text" id="mpSearch" class="inv-search-input"
           placeholder="Buscar método de pago..." autocomplete="off" />
    <span class="inv-search-count" id="mpCount">@total método@(total != 1 ? "s" : "")</span>
</div>

<div class="data-card" style="overflow:visible;">
    <div class="data-card-header">
        <div style="display:flex;align-items:center;gap:12px;">
            <span class="data-card-title">Métodos registrados</span>
            <span class="data-card-count" id="mpTC">@total</span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-credit-card-2-front"></i></div>
            <div class="empty-state-title">Sin métodos registrados</div>
            <div class="empty-state-sub">Agrega el primer método de pago</div>
        </div>
    }
    else
    {
        <table class="modern-table inv-table" id="mpTable">
            <thead>
                <tr>
                    <th scope="col">Nombre</th>
                    <th scope="col" class="col-actions">Acciones</th>
                </tr>
            </thead>
            <tbody id="mpBody">
                @foreach (var item in Model)
                {
                    <tr class="mp-row" data-nombre="@item.NombreMetodoPago.ToLower()">
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="width:32px;height:32px;border-radius:8px;background:var(--blue-100);display:flex;align-items:center;justify-content:center;color:var(--blue-700);font-size:0.85rem;flex-shrink:0;">
                                    <i class="bi bi-credit-card-2-front" aria-hidden="true"></i>
                                </div>
                                <span class="cell-primary">@Html.DisplayFor(modelItem => item.NombreMetodoPago)</span>
                            </div>
                        </td>
                        <td class="col-actions">
                            <div class="inv-menu-wrap">
                                <button class="inv-menu-btn" type="button" onclick="toggleMenu(this)" aria-label="Acciones">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <div class="inv-dropdown">
                                    <a asp-action="Details" asp-route-id="@item.MetodoPagoId" class="inv-dropdown-item">
                                        <i class="bi bi-eye"></i> Ver detalles
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.MetodoPagoId" class="inv-dropdown-item">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <div class="inv-dropdown-divider"></div>
                                    <a asp-action="Delete" asp-route-id="@item.MetodoPagoId" class="inv-dropdown-item inv-dropdown-danger">
                                        <i class="bi bi-trash3"></i> Eliminar
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" id="mpNoRes" style="display:none;">
            <div class="empty-state-icon"><i class="bi bi-search"></i></div>
            <div class="empty-state-title">Sin resultados</div>
            <div class="empty-state-sub">No se encontró ningún método con ese nombre</div>
        </div>
    }
</div>

@section Scripts {
<script>
const mpRows  = () => [...document.querySelectorAll('#mpBody .mp-row')];
const mpNoRes = document.getElementById('mpNoRes');
const mpCount = document.getElementById('mpCount');
const mpTC    = document.getElementById('mpTC');

document.getElementById('mpSearch')?.addEventListener('input', function () {
    const q = this.value.toLowerCase();
    let vis = 0;
    mpRows().forEach(r => {
        const show = !q || r.dataset.nombre.includes(q);
        r.style.display = show ? '' : 'none';
        if (show) vis++;
    });
    if (mpNoRes) mpNoRes.style.display = vis === 0 ? '' : 'none';
    if (mpCount) mpCount.textContent   = vis + ' método' + (vis !== 1 ? 's' : '');
    if (mpTC)    mpTC.textContent      = vis;
});

function toggleMenu(btn) {
    document.querySelectorAll('.inv-dropdown.open').forEach(d => {
        if (d !== btn.nextElementSibling) d.classList.remove('open');
    });
    btn.nextElementSibling.classList.toggle('open');
}
document.addEventListener('click', e => {
    if (!e.target.closest('.inv-menu-wrap'))
        document.querySelectorAll('.inv-dropdown.open').forEach(d => d.classList.remove('open'));
});
</script>
}
