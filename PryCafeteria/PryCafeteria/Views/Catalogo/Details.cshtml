@model PryCafeteria.Models.Producto
@{
    ViewData["Title"] = Model.NombreProducto;
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    var relacionados = ViewBag.Relacionados as List<PryCafeteria.Models.Producto> ?? new();
    var token = Html.AntiForgeryToken();
}

<!-- Volver al catálogo -->
<a asp-controller="Catalogo" asp-action="Index"
   style="display:inline-flex;align-items:center;gap:6px;color:#6b7280;text-decoration:none;font-size:.88rem;margin-bottom:20px;">
    <i class="bi bi-arrow-left"></i> Volver al menú
</a>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:36px;align-items:start;">

    <!-- ══ IMAGEN ══ -->
    <div style="border-radius:16px;overflow:hidden;background:#f3f4f6;">
        <img src="@(Model.Imagen ?? "/images/placeholder-producto.png")"
             alt="@Model.NombreProducto"
             style="width:100%;max-height:420px;object-fit:cover;"
             onerror="this.src='/images/placeholder-producto.png'" />
    </div>

    <!-- ══ INFO Y TAMAÑOS ══ -->
    <div>
        <span style="font-size:.78rem;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;">
            @Model.Categoria.NombreCategoria
        </span>
        <h1 style="font-size:1.6rem;font-weight:800;color:#111827;margin:6px 0 12px;">
            @Model.NombreProducto
        </h1>
        @if (!string.IsNullOrEmpty(Model.Descripcion))
        {
            <p style="color:#6b7280;font-size:.95rem;line-height:1.6;margin-bottom:20px;">
                @Model.Descripcion
            </p>
        }

        <!-- Tabla de tamaños y precios -->
        <h4 style="font-size:.9rem;font-weight:700;color:#374151;margin-bottom:10px;">Tamaños disponibles</h4>

        @if (!Model.ProductosTamanios.Any())
        {
            <p style="color:#9ca3af;">Este producto no tiene tamaños configurados.</p>
        }
        else
        {
            <div id="tamanios-lista" style="display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
                @foreach (var pt in Model.ProductosTamanios.OrderBy(pt => pt.Precio))
                {
                    var sinStock = pt.Stock <= 0 || !pt.Disponible;
                    <div class="tamanio-option @(sinStock ? "disabled" : "")"
                         data-pt-id="@pt.ProductoTamanioId"
                         data-precio="@pt.Precio.ToString("0.00")"
                         data-nombre-tamanio="@pt.Tamanio.NombreTamanio"
                         data-stock="@pt.Stock"
                         style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border:2px solid @(sinStock ? "#e5e7eb" : "#d1d5db");border-radius:10px;cursor:@(sinStock ? "default" : "pointer");opacity:@(sinStock ? ".5" : "1");transition:border-color .15s;">
                        <div>
                            <span style="font-weight:600;color:#111827;">@pt.Tamanio.NombreTamanio</span>
                            @if (sinStock)
                            {
                                <span style="margin-left:8px;font-size:.75rem;color:#ef4444;font-weight:600;">Sin stock</span>
                            }
                            else
                            {
                                <span style="margin-left:8px;font-size:.75rem;color:#6b7280;">@pt.Stock disponibles</span>
                            }
                        </div>
                        <span style="font-weight:700;color:#1B4332;font-size:1.05rem;">S/. @pt.Precio.ToString("0.00")</span>
                    </div>
                }
            </div>

            <!-- Precio seleccionado -->
            <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;">
                <span id="tamanio-seleccionado-label" style="font-size:.9rem;color:#374151;">Selecciona un tamaño</span>
                <span id="precio-seleccionado" style="font-size:1.4rem;font-weight:800;color:#1B4332;"></span>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form id="form-agregar" style="display:flex;gap:10px;align-items:center;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="pt-id-selected" name="productoTamanioId" value="" />
                    <div style="display:flex;align-items:center;border:1px solid #d1d5db;border-radius:8px;overflow:hidden;">
                        <button type="button" onclick="cambiarCantidad(-1)"
                                style="padding:8px 12px;background:none;border:none;cursor:pointer;font-size:1rem;">−</button>
                        <input type="number" id="cantidad-input" name="cantidad" value="1" min="1"
                               style="width:48px;text-align:center;border:none;font-weight:600;font-size:.95rem;" readonly />
                        <button type="button" onclick="cambiarCantidad(1)"
                                style="padding:8px 12px;background:none;border:none;cursor:pointer;font-size:1rem;">+</button>
                    </div>
                    <button type="button" id="btn-agregar"
                            onclick="agregarAlCarrito()"
                            disabled
                            style="flex:1;padding:10px 20px;background:#1B4332;color:#fff;border:none;border-radius:8px;font-weight:700;font-size:.95rem;cursor:pointer;opacity:.5;transition:opacity .15s;">
                        <i class="bi bi-cart-plus me-1"></i>
                        <span id="btn-texto">Selecciona un tamaño</span>
                    </button>
                </form>
                <div id="msg-carrito" style="margin-top:10px;font-size:.88rem;"></div>
            }
            else
            {
                <a asp-controller="Cuentas" asp-action="Login"
                   asp-route-returnUrl="/Catalogo/Details/@Model.ProductoId"
                   style="display:block;text-align:center;padding:12px;background:#1B4332;color:#fff;border-radius:8px;text-decoration:none;font-weight:700;">
                    Inicia sesión para agregar al carrito
                </a>
            }
        }
    </div>
</div>

<!-- ══ PRODUCTOS RELACIONADOS ══ -->
@if (relacionados.Any())
{
    <hr style="margin:40px 0 24px;border-color:#e5e7eb;" />
    <h3 style="font-size:1.1rem;font-weight:700;color:#111827;margin-bottom:16px;">Productos relacionados</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;">
        @foreach (var rel in relacionados)
        {
            var precioRel = rel.ProductosTamanios.Any() ? rel.ProductosTamanios.Min(p => p.Precio) : 0m;
            <a asp-controller="Catalogo" asp-action="Details" asp-route-id="@rel.ProductoId"
               style="background:#fff;border-radius:12px;overflow:hidden;text-decoration:none;box-shadow:0 1px 4px rgba(0,0,0,.08);display:block;">
                <img src="@(rel.Imagen ?? "/images/placeholder-producto.png")"
                     alt="@rel.NombreProducto"
                     style="width:100%;height:120px;object-fit:cover;"
                     onerror="this.src='/images/placeholder-producto.png'" />
                <div style="padding:10px 12px;">
                    <p style="font-size:.85rem;font-weight:700;color:#111827;margin:0 0 4px;">@rel.NombreProducto</p>
                    @if (precioRel > 0)
                    {
                        <p style="font-size:.8rem;color:#1B4332;font-weight:600;margin:0;">Desde S/. @precioRel.ToString("0.00")</p>
                    }
                </div>
            </a>
        }
    </div>
}

@section Scripts {
<script>
var tamanioSeleccionado = null;
var stockSeleccionado = 0;

document.querySelectorAll('.tamanio-option:not(.disabled)').forEach(function(el) {
    el.addEventListener('click', function() {
        document.querySelectorAll('.tamanio-option').forEach(o => {
            o.style.borderColor = o.classList.contains('disabled') ? '#e5e7eb' : '#d1d5db';
            o.style.background = '';
        });
        el.style.borderColor = '#1B4332';
        el.style.background = '#f0fdf4';

        tamanioSeleccionado = el.dataset.ptId;
        stockSeleccionado = parseInt(el.dataset.stock);
        var precio = el.dataset.precio;
        var nombre = el.dataset.nombreTamanio;

        document.getElementById('pt-id-selected').value = tamanioSeleccionado;
        document.getElementById('tamanio-seleccionado-label').textContent = nombre + ' seleccionado';
        document.getElementById('precio-seleccionado').textContent = 'S/. ' + precio;

        var btn = document.getElementById('btn-agregar');
        btn.disabled = false;
        btn.style.opacity = '1';
        document.getElementById('btn-texto').textContent = 'Agregar ' + nombre + ' al carrito';

        // Ajustar max cantidad
        document.getElementById('cantidad-input').max = stockSeleccionado;
        var cant = parseInt(document.getElementById('cantidad-input').value);
        if (cant > stockSeleccionado) document.getElementById('cantidad-input').value = stockSeleccionado;
    });
});

function cambiarCantidad(delta) {
    var input = document.getElementById('cantidad-input');
    var val = parseInt(input.value) + delta;
    var max = stockSeleccionado > 0 ? stockSeleccionado : 99;
    if (val < 1) val = 1;
    if (val > max) val = max;
    input.value = val;
}

function agregarAlCarrito() {
    if (!tamanioSeleccionado) return;
    var cantidad = document.getElementById('cantidad-input').value;
    var btn = document.getElementById('btn-agregar');
    btn.disabled = true;
    btn.style.opacity = '.6';

    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
    fetch('/Carrito/Agregar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: '__RequestVerificationToken=' + encodeURIComponent(token)
            + '&productoTamanioId=' + tamanioSeleccionado
            + '&cantidad=' + cantidad
    })
    .then(r => r.json())
    .then(data => {
        var msg = document.getElementById('msg-carrito');
        if (data.ok) {
            actualizarBadgeCarrito(data.totalItems);
            msg.innerHTML = '<span style="color:#16a34a"><i class="bi bi-check-circle me-1"></i>' +
                (data.advertencia || '¡Agregado al carrito!') + '</span>';
            document.getElementById('btn-texto').textContent = '✓ Agregado';
        } else {
            msg.innerHTML = '<span style="color:#ef4444"><i class="bi bi-x-circle me-1"></i>' + data.mensaje + '</span>';
        }
        setTimeout(() => {
            btn.disabled = false;
            btn.style.opacity = '1';
            msg.innerHTML = '';
            document.getElementById('btn-texto').textContent = 'Agregar al carrito';
        }, 2500);
    });
}
</script>
}
