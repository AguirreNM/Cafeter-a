@model IEnumerable<PryCafeteria.Models.Tamanio>
@{ ViewData["Title"] = "Tamaños"; var total = Model.Count(); }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Tamaños</h1>
        <p class="page-subtitle">Gestiona los tamaños disponibles para las variantes de productos</p>
    </div>
    <a asp-action="Create" class="btn-cta">
        <i class="bi bi-plus-lg" aria-hidden="true"></i> Nuevo Tamaño
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle" aria-hidden="true"></i> @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-circle" aria-hidden="true"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<!-- Búsqueda -->
<div class="inv-search-bar">
    <i class="bi bi-search inv-search-icon"></i>
    <input type="text" id="tamSearch" class="inv-search-input"
           placeholder="Buscar tamaño..." autocomplete="off" />
    <span class="inv-search-count" id="tamCount">@total tamaño@(total != 1 ? "s" : "")</span>
</div>

<div class="data-card">
    <div class="data-card-header">
        <span class="data-card-title">Lista de tamaños</span>
        <span class="data-card-count" id="tamTableCount">@total</span>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon"><i class="bi bi-rulers"></i></div>
            <div class="empty-state-title">Sin tamaños registrados</div>
            <div class="empty-state-sub">Crea el primer tamaño (Ej: Tall, Grande, Venti)</div>
        </div>
    }
    else
    {
        <table class="modern-table" id="tamTable">
            <thead>
                <tr>
                    <th scope="col">Nombre</th>
                    <th scope="col" style="width:100px;text-align:right;">Acciones</th>
                </tr>
            </thead>
            <tbody id="tamBody">
                @foreach (var item in Model)
                {
                    <tr class="tam-row" data-nombre="@item.NombreTamanio.ToLower()">
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="width:32px;height:32px;border-radius:8px;background:var(--green-100);display:flex;align-items:center;justify-content:center;color:var(--green-800);font-size:0.85rem;flex-shrink:0;">
                                    <i class="bi bi-rulers" aria-hidden="true"></i>
                                </div>
                                <span class="cell-primary">@Html.DisplayFor(modelItem => item.NombreTamanio)</span>
                            </div>
                        </td>
                        <td style="text-align:right;">
                            <div class="inv-menu-wrap">
                                <button class="inv-menu-btn" type="button" onclick="toggleMenu(this)" aria-label="Acciones">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <div class="inv-dropdown">
                                    <a asp-action="Edit" asp-route-id="@item.TamanioId" class="inv-dropdown-item">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <div class="inv-dropdown-divider"></div>
                                    <a asp-action="Delete" asp-route-id="@item.TamanioId" class="inv-dropdown-item inv-dropdown-danger">
                                        <i class="bi bi-trash3"></i> Eliminar
                                    </a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" id="tamNoResults" style="display:none;">
            <div class="empty-state-icon"><i class="bi bi-search"></i></div>
            <div class="empty-state-title">Sin resultados</div>
            <div class="empty-state-sub">No se encontró ningún tamaño con ese nombre</div>
        </div>
    }
</div>

@section Scripts {
<script>
const tamRows  = () => [...document.querySelectorAll('#tamBody .tam-row')];
const tamNoRes = document.getElementById('tamNoResults');
const tamCount = document.getElementById('tamCount');
const tamTC    = document.getElementById('tamTableCount');

document.getElementById('tamSearch')?.addEventListener('input', function () {
    const q = this.value.toLowerCase();
    let vis = 0;
    tamRows().forEach(r => {
        const show = !q || r.dataset.nombre.includes(q);
        r.style.display = show ? '' : 'none';
        if (show) vis++;
    });
    if (tamNoRes) tamNoRes.style.display = vis === 0 ? '' : 'none';
    if (tamCount) tamCount.textContent   = vis + ' tamaño' + (vis !== 1 ? 's' : '');
    if (tamTC)    tamTC.textContent      = vis;
});

function toggleMenu(btn) {
    document.querySelectorAll('.inv-dropdown.open').forEach(d => {
        if (d !== btn.nextElementSibling) d.classList.remove('open');
    });
    btn.nextElementSibling.classList.toggle('open');
}
document.addEventListener('click', e => {
    if (!e.target.closest('.inv-menu-wrap'))
        document.querySelectorAll('.inv-dropdown.open').forEach(d => d.classList.remove('open'));
});
</script>
}
