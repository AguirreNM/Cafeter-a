@model PryCafeteria.Models.Tamanio
@{ ViewData["Title"] = "Eliminar Tamaño"; }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Eliminar Tamaño</h1>
        <p class="page-subtitle">Esta acción no se puede deshacer</p>
    </div>
</div>

<div style="max-width:480px;margin:0 auto;">
    <div class="delete-card">
        <div class="delete-banner">
            <div class="delete-banner-icon">
                <i class="bi bi-trash3" style="color:var(--red-600);" aria-hidden="true"></i>
            </div>
            <div>
                <div class="delete-banner-title">¿Eliminar este tamaño?</div>
                <div class="delete-banner-sub">Las variantes asociadas quedarán sin tamaño asignado</div>
            </div>
        </div>
        <div class="info-grid">
            <span class="info-label">Nombre</span>
            <span class="info-value" style="font-weight:700;">@Html.DisplayFor(model => model.NombreTamanio)</span>
        </div>
        <div style="padding:0 24px 24px;">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="TamanioId" />
                <div class="form-actions">
                    <button type="submit" class="btn-danger-submit">
                        <i class="bi bi-trash3" aria-hidden="true"></i> Confirmar Eliminación
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancelar y Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>