@model PryCafeteria.Models.Tamanio
@{ ViewData["Title"] = "Detalle del Tamaño"; }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Detalle del Tamaño</h1>
        <p class="page-subtitle">Información del tamaño seleccionado</p>
    </div>
    <div style="display:flex;gap:8px;">
        <a asp-action="Edit" asp-route-id="@Model?.TamanioId" class="btn-cta">
            <i class="bi bi-pencil" aria-hidden="true"></i> Editar
        </a>
        <a asp-action="Index" class="btn-cancel" style="width:auto;padding:0.52rem 1rem;">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Volver
        </a>
    </div>
</div>

<div style="max-width:640px;margin:0 auto;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon">
                <i class="bi bi-rulers" aria-hidden="true"></i>
            </div>
            <div>
                <div class="form-card-title">@Html.DisplayFor(model => model.NombreTamanio)</div>
                <div class="form-card-subtitle">ID #@Model?.TamanioId</div>
            </div>
        </div>
        <div class="info-grid">
            <span class="info-label">Nombre</span>
            <span class="info-value" style="font-size:1rem;font-weight:700;">@Html.DisplayFor(model => model.NombreTamanio)</span>
        </div>
    </div>
</div>
