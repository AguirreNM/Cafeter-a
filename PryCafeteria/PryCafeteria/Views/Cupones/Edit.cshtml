@model PryCafeteria.Models.Cupone
@{ ViewData["Title"] = "Editar Cupón"; }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Editar Cupón</h1>
        <p class="page-subtitle">Modifica los datos del cupón seleccionado</p>
    </div>
    <a asp-action="Index" class="btn-cancel" style="width:auto;padding:0.52rem 1rem;">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Volver
    </a>
</div>

<div style="max-width:560px;margin:0 auto;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon gold">
                <i class="bi bi-ticket-perforated" aria-hidden="true"></i>
            </div>
            <div>
                <div class="form-card-title">Editar cupón</div>
                <div class="form-card-subtitle">Los cambios aplican de inmediato</div>
            </div>
        </div>
        <div class="form-card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <input type="hidden" asp-for="CuponId" />

                <div class="field-group">
                    <label asp-for="NombreCupon" class="form-label">
                        <i class="bi bi-ticket" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>Nombre del Cupón
                    </label>
                    <input asp-for="NombreCupon" class="form-control" placeholder="Ej: PROMO10" />
                    <span asp-validation-for="NombreCupon" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="TipoDescuento" class="form-label">
                        <i class="bi bi-tags" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>Tipo de Descuento
                    </label>
                    <select asp-for="TipoDescuento" class="form-select">
                        <option value="">-- Seleccione un tipo --</option>
                        <option value="Porcentaje">% Porcentaje</option>
                        <option value="Monto fijo">S/ Monto fijo</option>
                    </select>
                    <span asp-validation-for="TipoDescuento" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="ValorDescuento" class="form-label">
                        <i class="bi bi-percent" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>Valor de Descuento
                    </label>
                    <input asp-for="ValorDescuento" class="form-control" placeholder="Ej: 10" />
                    <span asp-validation-for="ValorDescuento" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="FechaInicio" class="form-label">
                        <i class="bi bi-calendar-event" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>Fecha de Inicio
                    </label>
                    <input asp-for="FechaInicio" class="form-control" />
                    <span asp-validation-for="FechaInicio" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="FechaFin" class="form-label">
                        <i class="bi bi-calendar-x" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>Fecha Final
                    </label>
                    <input asp-for="FechaFin" class="form-control" />
                    <span asp-validation-for="FechaFin" class="field-error"></span>
                </div>

                <div class="field-group">
                    <div class="toggle-field">
                        <div>
                            <div class="toggle-info-title">Cupón Activo</div>
                            <div class="toggle-info-desc">El cupón podrá ser canjeado por clientes</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input asp-for="Activo" class="form-check-input" type="checkbox" role="switch" />
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-floppy" aria-hidden="true"></i> Guardar Cambios
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
