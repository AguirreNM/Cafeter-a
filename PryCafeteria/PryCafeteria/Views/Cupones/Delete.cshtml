@model PryCafeteria.Models.Cupone
@{ ViewData["Title"] = "Eliminar Cupón"; }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Eliminar Cupón</h1>
        <p class="page-subtitle">Esta acción no se puede deshacer</p>
    </div>
</div>

<div style="max-width:560px;margin:0 auto;">
    <div class="delete-card">
        <div class="delete-banner">
            <div class="delete-banner-icon">
                <i class="bi bi-ticket-perforated" style="color:var(--red-600);" aria-hidden="true"></i>
            </div>
            <div>
                <div class="delete-banner-title">¿Eliminar este cupón?</div>
                <div class="delete-banner-sub">El cupón dejará de estar disponible permanentemente</div>
            </div>
        </div>
        <div class="info-grid">
            <span class="info-label">Nombre</span>
            <span class="info-value" style="font-weight:700;">@Html.DisplayFor(model => model.NombreCupon)</span>
            <span class="info-label">Tipo</span>
            <span class="info-value">@Html.DisplayFor(model => model.TipoDescuento)</span>
            <span class="info-label">Valor</span>
            <span class="info-value">@Html.DisplayFor(model => model.ValorDescuento)</span>
            <span class="info-label">Inicio</span>
            <span class="info-value">@Model?.FechaInicio.ToString("dd/MM/yyyy HH:mm")</span>
            <span class="info-label">Fin</span>
            <span class="info-value">@Model?.FechaFin.ToString("dd/MM/yyyy HH:mm")</span>
            <span class="info-label">Estado</span>
            <span class="info-value">
                @if (Model?.Activo == true)
                {
                    <span class="badge-modern badge-vigente"><span class="dot" aria-hidden="true"></span>Activo</span>
                }
                else
                {
                    <span class="badge-modern badge-inactivo"><span class="dot" aria-hidden="true"></span>Inactivo</span>
                }
            </span>
        </div>
        <div style="padding:0 24px 24px;">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CuponId" />
                <div class="form-actions">
                    <button type="submit" class="btn-danger-submit">
                        <i class="bi bi-trash3" aria-hidden="true"></i> Confirmar Eliminación
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancelar y Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>