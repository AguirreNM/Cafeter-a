@model PryCafeteria.Models.ProductosTamanio

@{
    ViewData["Title"] = "Eliminar variante";
}

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Eliminar variante</h1>
        <p class="page-subtitle">Esta acción no se puede deshacer</p>
    </div>
</div>

<div style="max-width:520px;margin:0 auto;">
    <div class="delete-card">
        <div class="delete-banner">
            <div class="delete-banner-icon">
                <i class="bi bi-trash3" style="color:var(--red-600);" aria-hidden="true"></i>
            </div>
            <div>
                <div class="delete-banner-title">¿Confirmar eliminación?</div>
                <div class="delete-banner-sub">Se eliminarán permanentemente todos los datos de esta variante</div>
            </div>
        </div>

        <div class="info-grid">
            <div class="info-label">Producto</div>
            <div class="info-value">@Model?.Producto?.NombreProducto</div>

            <div class="info-label">Categoría</div>
            <div class="info-value">@(string.IsNullOrEmpty(Model?.Producto?.Categoria?.NombreCategoria) ? "—" : Model.Producto.Categoria.NombreCategoria)</div>

            <div class="info-label">Tamaño</div>
            <div class="info-value">@Model?.Tamanio?.NombreTamanio</div>

            <div class="info-label">Precio</div>
            <div class="info-value">
                <span style="font-weight:700;color:var(--green-800);">S/ @Model?.Precio.ToString("0.00")</span>
            </div>

            <div class="info-label">Stock</div>
            <div class="info-value">
                @if (Model?.Stock == 0)
                {
                    <span class="badge-modern badge-agotado"><span class="dot" aria-hidden="true"></span>Agotado</span>
                }
                else if (Model?.Stock <= 5)
                {
                    <span class="badge-modern badge-bajo"><span class="dot" aria-hidden="true"></span>@Model.Stock unidades</span>
                }
                else
                {
                    <span class="badge-modern badge-disponible"><span class="dot" aria-hidden="true"></span>@Model?.Stock unidades</span>
                }
            </div>

            <div class="info-label">Disponible</div>
            <div class="info-value">
                @if (Model?.Disponible == true)
                {
                    <span class="badge-modern badge-disponible"><span class="dot" aria-hidden="true"></span>Sí</span>
                }
                else
                {
                    <span class="badge-modern badge-nodisponible"><span class="dot" aria-hidden="true"></span>No</span>
                }
            </div>
        </div>

        <div style="padding:0 24px 24px;">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductoTamanioId" />
                <div class="form-actions">
                    <button type="submit" class="btn-danger-submit">
                        <i class="bi bi-trash3"></i> Eliminar variante
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancelar y Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>
