@model PryCafeteria.Models.Producto
@{ ViewData["Title"] = "Eliminar Producto"; }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Eliminar Producto</h1>
        <p class="page-subtitle">Esta acción no se puede deshacer</p>
    </div>
</div>

<div style="max-width:560px;margin:0 auto;">
    <div class="delete-card">
        <div class="delete-banner">
            <div class="delete-banner-icon">
                <i class="bi bi-trash3" style="color:var(--red-600);" aria-hidden="true"></i>
            </div>
            <div>
                <div class="delete-banner-title">¿Eliminar este producto?</div>
                <div class="delete-banner-sub">Se eliminará permanentemente del catálogo</div>
            </div>
        </div>

        <div class="info-grid">
            <span class="info-label">Nombre</span>
            <span class="info-value">@Html.DisplayFor(model => model.NombreProducto)</span>

            <span class="info-label">Descripción</span>
            <span class="info-value">@Html.DisplayFor(model => model.Descripcion)</span>

            <span class="info-label">Categoría</span>
            <span class="info-value">
                <span class="badge-modern badge-categoria">
                    <span class="dot" aria-hidden="true"></span>@Html.DisplayFor(model => model.Categoria.NombreCategoria)
                </span>
            </span>

            <span class="info-label">Disponible</span>
            <span class="info-value">@Html.DisplayFor(model => model.Disponible)</span>
        </div>

        <div style="padding:0 24px 24px;">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductoId" />
                <div class="form-actions">
                    <button type="submit" class="btn-danger-submit">
                        <i class="bi bi-trash3" aria-hidden="true"></i> Confirmar Eliminación
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancelar y Volver</a>
                </div>
            </form>
        </div>
    </div>
</div> 