@model PryCafeteria.Models.Producto
@{ ViewData["Title"] = "Editar Producto"; }

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Editar Producto</h1>
        <p class="page-subtitle">Modifica los datos del producto seleccionado</p>
    </div>
    <a asp-action="Index" class="btn-cancel" style="width:auto;padding:0.52rem 1rem;">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Volver
    </a>
</div>

<div style="max-width:580px;margin:0 auto;">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon gold">
                <i class="bi bi-pencil-square" aria-hidden="true"></i>
            </div>
            <div>
                <div class="form-card-title">Editar producto</div>
                <div class="form-card-subtitle">Los cambios se aplicarán de inmediato</div>
            </div>
        </div>
        <div class="form-card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <input type="hidden" asp-for="ProductoId" />

                <!-- Campo oculto para preservar imagen actual — HU-Productos E3 -->
                <input type="hidden" name="imagenActual" value="@Model.Imagen" />

                <!-- Nombre -->
                <div class="field-group">
                    <label asp-for="NombreProducto" class="form-label">
                        <i class="bi bi-tag" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>
                        Nombre del Producto <span class="text-danger">*</span>
                    </label>
                    <input asp-for="NombreProducto" class="form-control" maxlength="100" />
                    <span asp-validation-for="NombreProducto" class="field-error"></span>
                </div>

                <!-- Descripción -->
                <div class="field-group">
                    <label asp-for="Descripcion" class="form-label">
                        <i class="bi bi-text-left" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>
                        Descripción
                    </label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"
                              maxlength="200" id="descTextarea"></textarea>
                    <div class="d-flex justify-content-between">
                        <span asp-validation-for="Descripcion" class="field-error"></span>
                        <small class="text-muted ms-auto" id="descCounter">@(Model.Descripcion?.Length ?? 0) / 200</small>
                    </div>
                </div>

                <!-- Categoría -->
                <div class="field-group">
                    <label asp-for="CategoriaId" class="form-label">
                        <i class="bi bi-folder2" style="color:var(--gold-700);margin-right:5px;" aria-hidden="true"></i>
                        Categoría <span class="text-danger">*</span>
                    </label>
                    <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId"></select>
                    <span asp-validation-for="CategoriaId" class="field-error"></span>
                </div>

                <!-- Imagen actual + opción de reemplazar -->
                <div class="field-group">
                    <label class="form-label">
                        <i class="bi bi-image" style="color:var(--green-800);margin-right:5px;" aria-hidden="true"></i>
                        Imagen del Producto
                    </label>

                    <!-- Imagen actual -->
                    <div style="margin-bottom:10px;">
                        <p class="field-hint mb-1">Imagen actual:</p>
                        @if (!string.IsNullOrEmpty(Model.Imagen))
                        {
                            <img src="@Model.Imagen" alt="Imagen actual"
                                 id="imgCurrentDisplay"
                                 style="width:120px;height:120px;object-fit:cover;
                                        border-radius:10px;border:2px solid var(--green-200);" />
                        }
                        else
                        {
                            <div style="width:120px;height:120px;border-radius:10px;
                                        border:2px dashed var(--green-200);display:flex;
                                        align-items:center;justify-content:center;
                                        color:var(--green-400);font-size:2rem;">
                                <i class="bi bi-image"></i>
                            </div>
                        }
                    </div>

                    <!-- Vista previa de nueva imagen -->
                    <div id="imgPreviewWrap" style="margin-bottom:10px;display:none;">
                        <p class="field-hint mb-1" style="color:var(--green-700);">Nueva imagen (reemplazará la actual):</p>
                        <img id="imgPreview" src="#" alt="Vista previa"
                             style="width:120px;height:120px;object-fit:cover;border-radius:10px;
                                    border:2px solid var(--green-300);" />
                    </div>

                    <input type="file" name="imagenArchivo" id="imagenArchivo"
                           class="form-control"
                           accept=".jpg,.jpeg,.png"
                           style="margin-top:6px;" />
                    <p class="field-hint">Formatos: .jpg, .jpeg, .png · Máximo 2 MB · Se redimensionará a 800×800 px.<br>
                        Si no seleccionas una nueva imagen, se conservará la actual.</p>
                    <span id="imgError" class="field-error" style="display:none;"></span>
                </div>

                <!-- Disponible -->
                <div class="field-group">
                    <div class="toggle-field">
                        <div>
                            <div class="toggle-info-title">Producto Disponible</div>
                            <div class="toggle-info-desc">Visible para los clientes en el menú</div>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input asp-for="Disponible" class="form-check-input" type="checkbox" role="switch" />
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-floppy" aria-hidden="true"></i> Guardar Cambios
                    </button>
                    <a asp-action="Index" class="btn-cancel">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
    const fileInput   = document.getElementById('imagenArchivo');
    const preview     = document.getElementById('imgPreview');
    const previewWrap = document.getElementById('imgPreviewWrap');
    const imgError    = document.getElementById('imgError');
    const MAX_SIZE    = 2 * 1024 * 1024;
    const ALLOWED_EXT = ['jpg', 'jpeg', 'png'];

    fileInput.addEventListener('change', function () {
        imgError.style.display = 'none';
        const file = this.files[0];
        if (!file) { previewWrap.style.display = 'none'; return; }

        const ext = file.name.split('.').pop().toLowerCase();
        if (!ALLOWED_EXT.includes(ext)) {
            imgError.textContent = 'Solo se permiten imágenes .jpg, .jpeg y .png';
            imgError.style.display = 'block';
            previewWrap.style.display = 'none';
            this.value = '';
            return;
        }
        if (file.size > MAX_SIZE) {
            imgError.textContent = 'La imagen no puede superar 2 MB';
            imgError.style.display = 'block';
            previewWrap.style.display = 'none';
            this.value = '';
            return;
        }
        const reader = new FileReader();
        reader.onload = e => {
            preview.src = e.target.result;
            previewWrap.style.display = 'block';
        };
        reader.readAsDataURL(file);
    });

    // Contador descripción
    const descTA      = document.getElementById('descTextarea');
    const descCounter = document.getElementById('descCounter');
    if (descTA) {
        descTA.addEventListener('input', () => {
            descCounter.textContent = descTA.value.length + ' / 200';
        });
    }
    </script>
}
